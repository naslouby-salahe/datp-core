# Copy to .env and edit locally. Both variables are optional; the path
# resolver and hardware utility fall back to safe defaults when unset.

# Overrides the raw dataset root normally resolved to <repo_root>/data/raw.
# Use only when raw data lives outside the repository's data/raw symlink.
DATP_DATA_ROOT=

# Overrides automatic device selection (cpu | cuda | auto). Defaults to auto.
DATP_DEVICE=
